#include <iostream>
#include <string>
#include <climits>
using namespace std;
int main(){
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);
    string s;
   
    if (!getline(cin, s)) return 0;
    int i=0;
    int n=s.length();
    while (i < n && s[i] == ' ') {
        i++;
    }
    if (i==n) {
        cout << 0<< "\n";
        return 0;
    }
    int sign =1;
    if (s[i] == '+') {
        i++;
    } else if (s[i] == '-') {
        sign= -1;
        i++;
    }
    int res = 0;
    while (i< n && s[i] >= '0' && s[i] <= '9') {
        int digit = s[i] - '0';
        if (sign== 1 && (res> INT_MAX / 10 || (res == INT_MAX / 10 && digit > 7))) {
            cout << INT_MAX << "\n";
            return 0;
        }
        if (sign == -1 && (res > INT_MAX / 10 || (res == INT_MAX / 10 && digit > 8))) {
            cout << INT_MIN << "\n";
            return 0;
        }
        res = res * 10 + digit;
        i++;
    }
    cout <<sign * res << "\n";
    return 0;
}
