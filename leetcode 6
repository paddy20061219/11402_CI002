#include <bits/stdc++.h>

using namespace std;
int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);
    string s;
    int numRows;
    cin >> s >> numRows;
    if (numRows == 1) {
        cout << s << "\n";
        return 0;
    }
    
    vector<string>rows(numRows);
    int row = 0;
    int dir =  1;
    for (char c : s) {
        rows[row] += c;
        if (row == 0) dir = 1;
        else if (row == numRows - 1) dir = -1;
        row += dir;
    }
    string res;
    for (string r : rows) {
        res += r;
    }
    cout << res << "\n";
    
     return 0;

}
