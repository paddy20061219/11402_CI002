class Solution {
public:
int dfs(TreeNode* node) {
        if (!node) return 0; 

        int lh = dfs(node->left);
        if (lh == -1) return -1;  

        int rh = dfs(node->right);
        if (rh == -1) return -1;  

        if (abs(lh - rh) > 1) return -1;  

        return max(lh, rh) + 1;  
    }

    bool isBalanced(TreeNode* root) {
        return dfs(root) != -1;
    }
};
