class Solution {
public:
    ListNode* sortList(ListNode* head) {
        if (!head || !head->next) return head;

        vector<int> vals;
        ListNode* curr = head;
        while (curr) {
            vals.push_back(curr->val);
            curr = curr->next;
        }

        sort(vals.begin(), vals.end());

        curr = head;
        for (int i = 0; i < vals.size(); i++) {
            curr->val = vals[i];
            curr = curr->next;
        }

        return head;
    }
};
