class Solution {
public:
    int dfs(TreeNode* node, int curVal) {
      if (!node) return 0;

        curVal = (curVal << 1) | node->val;  

        if (!node->left && !node->right) return curVal;

  return dfs(node->left, curVal) + dfs(node->right, curVal);
    }

    int sumRootToLeaf(TreeNode* root) {
        return dfs(root, 0);
    }
};
