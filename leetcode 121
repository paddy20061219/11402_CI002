class Solution {
    func maxProfit(_ prices: [Int]) -> Int {
        var left = 0
        var maxProfit = 0

        for right in 0..<prices.count {
            if prices[right] - prices[left] < 0 {
                left = right
            }
            maxProfit = max(maxProfit, prices[right] - prices[left])
        }
        return maxProfit
    }
}
