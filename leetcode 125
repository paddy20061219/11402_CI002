#include <iostream>
#include <string>
#include <cctype>

using namespace std;
int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);
    string s;
    getline(cin, s);
    string t;
    for (char c:s) {
        if (isalnum(c)) {
            t += tolower(c);
        }

    }
    
    int l = 0, r = t.length() - 1;
    while (l < r) {
        if (t[l] != t[r]) {
            cout << "false\n";
            return 0;
        }
        
        l++;
        r--;
    }
    
    cout << "true\n";
    
    return 0;

}
