#include <bits/stdc++.h>

using namespace std;
int main(){
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);
    int x;
    cin >> x;
    if (x < 0) {
        cout << "false\n";
        return 0;
    }
    
     int original = x;
    int rev = 0;
    while (x > 0) {
        rev = rev * 10 + x % 10;
        x /= 10;
    }
    cout << (original == rev ? "true" : "false") << "\n";
    
return 0;
}
