class Solution:
    def countNodes(self, root):
        if root is None:
            return 0
        


        left_height = 0
        node = root
        while node:
            left_height += 1
            node = node.left
   
        right_height = 0
        node = root
        while node:
            right_height += 1
            node = node.right
        
  
        if left_height == right_height:
            return (1 << left_height) - 1
        else:
            left_count  = self.countNodes(root.left)
            right_count = self.countNodes(root.right)
            return left_count + right_count + 1
