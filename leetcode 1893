#include <vector>
#include <algorithm>

class Solution {


public:
    bool isCovered(std::vector<std::vector<int>>& ranges, int left, int right) {
        std::vector<int> diff(52, 0);
        for (const auto& r : ranges) {
            diff[r[0]]++;
            diff[r[1] + 1]--;
        }
        
    int curr = 0;
        for (int i = 1; i <= right; ++i) {
            curr += diff[i];
            if (i >= left && curr <= 0) {
                return false;
            }
        }
        return true;
   

}
};
