#include <vector>
#include <queue>

class KthLargest {
private:
   
    std::priority_queue<int, std::vector<int>, std::greater<int>> minHeap;
    int kSize;

public:
    KthLargest(int k, std::vector<int>& nums) {
        kSize = k;
        
        for (int num : nums) {
            add(num);
        }
    }
    
    int add(int val) {
        minHeap.push(val);
        if (minHeap.size() > kSize) {
            minHeap.pop();
        }




        return minHeap.top();
    }
};
